# Aiven Cloud Configuration Template
# Tệp này là mẫu cấu hình cho Aiven Cloud
# Hãy sao chép thành .env.local và điền thông tin từ Aiven Dashboard

# ===== AIVEN DATABASE CREDENTIALS =====
# Lấy từ Aiven Dashboard → Connection tab

# Địa chỉ host của Aiven MySQL
# Ví dụ: techstore-mysql-abc123.a.aivencloud.com
AIVEN_DB_HOST=your_aiven_host_here

# Port MySQL trên Aiven (thường là 13006)
AIVEN_DB_PORT=13006

# Tên database
# Ví dụ: techstoredb
AIVEN_DB_NAME=your_database_name

# Username (mặc định là avnadmin)
AIVEN_DB_USERNAME=avnadmin

# Password từ Aiven
AIVEN_DB_PASSWORD=your_aiven_password_here

# ===== URI CONNECTION STRING (AUTO BUILD) =====
# Nếu dùng toàn bộ URI, có thể dùng:
# AIVEN_DB_URL=jdbc:mysql://HOST:PORT/DATABASE?useUnicode=true&characterEncoding=utf8mb4&serverTimezone=UTC

# ===== ALTERNATIVE: Direct JDBC URL =====
# Uncomment nếu muốn dùng cách khác
# DB_URL=jdbc:mysql://techstore-mysql-abc123.a.aivencloud.com:13006/techstoredb

# ===== CONNECTION POOL SETTINGS (Optional) =====
DB_HIKARI_MAX_POOL_SIZE=10
DB_HIKARI_MIN_IDLE=2
DB_HIKARI_CONNECTION_TIMEOUT=30000
